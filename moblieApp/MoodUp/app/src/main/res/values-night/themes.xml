<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MoodUp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/pakistan_green</item>
        <item name="colorPrimaryVariant">@color/hunter_green</item>
        <item name="colorOnPrimary">@color/timber_wolf</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/light_yellow</item>
        <item name="colorSecondaryVariant">@color/dark_yellow</item>
        <item name="colorOnSecondary">@color/dark_green</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/viridian</item>
        <item name="materialAlertDialogTheme">@style/CustomDialogTheme</item>
        <item name="textInputStyle">@style/CustomTextInput</item>
    </style>

    <style name="CustomDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/delft_blue</item>
        <item name="android:textColorPrimary">@color/timber_wolf</item>
        <item name="android:textColorSecondary">@color/ash_gray</item>
        <item name="colorPrimary">@color/tiffany_blue</item>
    </style>

    <style name="CustomTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/dark_green</item>
        <item name="hintTextColor">@color/timber_wolf</item>
        <item name="boxBackgroundColor">@color/pakistan_green</item>
    </style>
</resources>