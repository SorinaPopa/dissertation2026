<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_journal_entry"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/journal_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="apr 28, 13:30"
            android:textColor="@color/dark_brown"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/journal_mood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Happy"
            android:textColor="@color/pakistan_green"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/journal_entry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginVertical="10dp"
        android:text="Journal Entry"
        android:textAlignment="textStart"
        android:textColor="@color/pakistan_green"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/journal_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Score: 0.45"
        android:textColor="@color/dark_brown"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Suggestion:"
        android:textColor="@color/dark_brown"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/journal_suggestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You're doing great!"
        android:textColor="@color/dark_brown"
        android:textSize="14sp" />

</LinearLayout>