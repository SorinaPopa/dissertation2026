<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="journalViewModel"
            type="com.example.moodup.ui.journal.JournalViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="com.example.moodup.ui.chat.ChatFragment">

        <TextView
            android:id="@+id/journalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="How are you feeling right now?"
            android:textAlignment="center"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/journalSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Every entry changes the smart light based on your mood!"
            android:textAlignment="center"
            android:textColor="@color/dark_brown"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/journalTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/journalEntriesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/journalEntryInput"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/journalSubtitle" />

        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="45sp"
            android:layout_height="50sp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_displayed_data"
            android:backgroundTint="@color/light_yellow"
            android:onClick="@{()->journalViewModel.onClickMicButton()}"
            app:layout_constraintBottom_toBottomOf="@id/sendButton"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/journalEntryInput"
            app:layout_constraintTop_toTopOf="@id/sendButton"
            app:srcCompat="@drawable/ic_mic_black_24" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/journalEntryInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/micButton"
            app:layout_constraintRight_toLeftOf="@id/sendButton">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="start typing..."
                android:text="@={journalViewModel.journalEntryInput}" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="5dp"
            android:onClick="@{()->journalViewModel.onClickSendButton()}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/journalEntryInput"
            app:layout_constraintRight_toRightOf="parent"
            app:srcCompat="@drawable/ic_send_black_24" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>